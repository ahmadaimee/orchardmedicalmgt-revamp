		<script type="text/javascript">
			window.__lc = window.__lc || {};
			window.__lc.license = 10910567;;
			window.__lc.chat_between_groups = false;
		</script>

	<div id="my-wrapper" aria-label="This is a Customer Live Chat." class="outline style-background-color style-border-color" role="dialog">
		<div id="livechat-eye-catcher" class="plcustomchat">
        <div class="lcustomchat">
        </div><div id="livechat-eye-catcher-img" class="icustomchat">
        <img alt="Questions? Chat now!" src="https://www.eclinicalworks.com/wp-content/themes/eclinicalworks/img/livechat.png"></div></div>
			 <div aria-label="This is a Customer Live Chat." class="chat-dialog">  
       			<a id="my-title"><h2 class="newchath2"><span id="title-text">Questions? Chat Now!</span></h2></a>

      			<span class="my-icon-close" role="button" tabindex="0" aria-label="Close chat window"></span>
  
        <div class="inside">  
             
           <h3 class="p-choose-group">
				Are you a current eClinicalWorks customer?
			</h3> 
            <div class="choose-group">  
                <div class="groups">  
                    <a href="#" id="live-chart-button-yes" class="a-group marginr" data-group="2" aria-label="Yes, I am a current eClinicalWorks customer">Yes</a>   
                    <a href="#" id="live-chart-button-no" class="a-group marginr" data-group="0" aria-label="No, I am not a current eClinicalWorks customer">No</a>    
                </div>  
            </div>  
        </div>  
    </div>  
</div>  
		<script type="text/javascript">
		ro=0;
		jQuery(document).ready(function()
			{
			 jQuery(window).resize(function() {
	       
			var windowheigth=window.innerHeight;
		   if(ro==1 || jQuery('#my-wrapper').css('minHeight') > 50)
		   {
			        if(windowheigth < 380)
        			{
        				jQuery('#my-wrapper').css('min-height',windowheigth).css('overflow','auto');
        
        			}
        			else
        			{
        				jQuery('#my-wrapper').css({'minHeight':'380px','overflow':'unset'});
        			}
		   }
		   ro=0;
});
				jQuery(".my-icon-close").bind("click", function() 
				{
					jQuery(this).hide();
					jQuery('#my-wrapper').css({'minHeight':'45px'});
					jQuery("#livechat-eye-catcher").show();
				}).hide();
				
				jQuery('#my-title').bind('click', function(){
					jQuery("#livechat-eye-catcher").hide();
					ro=1;
					jQuery(".my-icon-close").show();
					jQuery(window).trigger('resize');
					//jQuery('#my-wrapper').css({'minHeight':'380px'});
				});
				jQuery('#livechat-eye-catcher').bind('click', function(){
					jQuery("#livechat-eye-catcher").hide();
					ro=1;
					jQuery(".my-icon-close").show();
					jQuery(window).trigger('resize');
					//jQuery('#my-wrapper').css({'minHeight':'380px'});
				});
			
				
				
				
				
				jQuery(".a-group").bind("click", function() 
				{
					if(jQuery(this).data('group') == 0) {
					
						window.__lc.group = jQuery(this).data("group");
						jQuery('#loading-indicator').show();
						jQuery('.groups').hide();
						(function() {
							var lc = document.createElement('script');
							lc.type = 'text/javascript';
							lc.async = true;
							lc.src = ('https:' == document.location.protocol ? 'https://' : 'http://') + 'cdn.livechatinc.com/tracking.js';
							var s = document.getElementsByTagName('script')[0];
							s.parentNode.insertBefore(lc, s);
						})();
					} else {
						jQuery('.p-choose-group').hide();
						jQuery('.choose-group').html('<p class="pcustom">Please go to <a href="https://my.eclinicalworks.com/eCRM/jsp/index.jsp?utm_campaign=2019%20CHAT%20-%20Conversion%20Tacking&utm_source=eclinicalworks.com&utm_medium=CHAT&utm_content=current%20customer%20link%20to%20portal" target="_blank">my.eclinicalworks.com</a> to log a ticket or contact your Strategic Account Manager.</p>');
					}
				});

				
				if(typeof LC_API.chat_window_minimized === 'undefined')
				{
					var newTime = new Date().toLocaleString("en-US", {timeZone: "America/New_York"});
					newTime = new Date(newTime);
                    var hours=newTime.getHours();
					if(hours >=8 && hours<17)
					{ 
						jQuery('#my-wrapper').show();
						return false;
					}
					else
					{
						jQuery('#my-wrapper').hide();
					} 
					
					
				}
				else
				{
					LC_API.open_chat_window();
					return false;
				}
			});
			var LC_API = LC_API || {};
			LC_API.on_before_load = function()
			{
				jQuery('#my-wrapper').hide();
			};
			LC_API.on_after_load = function()
			{
				LC_API.open_chat_window();
			};
			LC_API.on_chat_window_minimized = function()
			{
				jQuery('div#livechat-compact-container').show();
			};
			
		</script>
<script>
jQuery(document).ready(function() {  
    jQuery('[title]').removeAttr('title');  
}); 
</script>
