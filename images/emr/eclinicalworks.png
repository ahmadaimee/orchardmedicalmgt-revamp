    <style>
			#my-wrapper
			{
				z-index: 99999;
				background-color: #fff !important;				
				border-color: #b02323 !important;
				border-bottom-width: 0;
				border-radius: 10px 10px 0 0;
				background-clip: padding-box;
				box-shadow: inset 1px 1px 1px rgba(255,255,255,.2);
				width: 370px;
				/*height: 430px;*/
				height: 45px;
				position: fixed;
				bottom: 0px;
				right: 30px;				
				border-radius: 4px 4px 0 0!important;
				box-shadow: 0 2px 25px rgba(0,0,0,.2)!important;
				background-clip: padding-box!important;
				display: none;
			}
			#loading-indicator
			{
				position: absolute;
				bottom: 150px;
				left: 185px;
				display: none;
			}
			#my-wrapper .inside
			{
				border-radius: 10px 10px 0 0;
				padding: 0px;
				width: 100%;
				height: 100%;
				background-color: #FFF;
			}

			.groups 
			{
				margin-top: 0px;
			}

			a.a-group 
			{
				width:110px;
				float: left;
				text-decoration: none;
				cursor: pointer;
				border-radius: 4px;
				padding: 14px;
				text-align: center;
				background: #dcdcdc;
				color: #000;
				margin-bottom: 20px;
			}
			
			

			div#livechat-compact-container 
			{
				display: none;
			}

			#my-title 
			{
				padding-top: 5px;
				padding-bottom: 5px;
				border-radius: 3px 3px 0 0;
				/*background-color: #358AD9 !important;*/
				background-color: #173e58 !important;
				float: left;
				width: 100%;

			}
			#my-title #title-text 
			{
				color: #fff;
				font-size: 16px!important;
				font-weight: 400!important;
				text-shadow: none!important;
				margin-left: 10px;
			}
			 
			.newchath2
			{
				color: #fff;
				font-size: 16px!important;
				font-weight: 400!important;
				text-shadow: none!important;
				margin-left: 10px;
				line-height:unset!important;
				font-family: 'robotolight', Arial, Helvetica, sans-serif;
			} 

			.my-icon-close {
				font-size: 17px;
				z-index: 99;
			}



			@font-face {
				font-family: 'icomoon';
				src:url('https://cdn.livechatinc.com/fonts/modern/livechat-modern-3b25a3b1eca2b7498bdf66a68006766a.eot?-zbydp9');
				src:url('https://cdn.livechatinc.com/fonts/modern/livechat-modern-3b25a3b1eca2b7498bdf66a68006766a.eot?#iefix-zbydp9') format('embedded-opentype'),
					url('https://cdn.livechatinc.com/fonts/modern/livechat-modern-3b25a3b1eca2b7498bdf66a68006766a.woff?-zbydp9') format('woff'),
					url('https://cdn.livechatinc.com/fonts/modern/livechat-modern-3b25a3b1eca2b7498bdf66a68006766a.ttf?-zbydp9') format('truetype'),
					url('https://cdn.livechatinc.com/fonts/modern/livechat-modern-3b25a3b1eca2b7498bdf66a68006766a.svg?-zbydp9#icomoon') format('svg');
				font-weight: normal;
				font-style: normal;
			}

			.my-icon-close
			{
				font-family: 'icomoon';
				speak: none;
				font-style: normal;
				font-weight: normal;
				font-variant: normal;
				text-transform: none;
				line-height: 1;

				/* Better Font Rendering =========== */
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				float: right;
				margin-right: 13px;
				cursor: pointer;
				color: #FFF;
				
				position: absolute;
				right: -4px;
				top: 9px;
				padding: 10px;
				display: block;
				z-index: 999;
			}

			.my-icon-close:before {
				content: "\e601";
			}

			p.p-choose-group
			{
				padding-top: 60px;
				text-align: center
			}
			h3.p-choose-group
			{
				padding-top: 60px;
				text-align: center;
				font-size:20px;
				line-height:28px;
				margin-top:unset;
			}
			.pcustom
			{
				padding: 20px;
				display: block;
				float: left;
				width: 100%;
				height: 100%;
			}
			.choose-group 
			{
				width: 100%;
				float: left;
				display: block;
			}
			.choose-group > .groups
			{
				width: 140px;
				margin: 30px auto 0;
			}
			.plcustomchat
			{
				position: absolute;
				visibility: visible;
				z-index: 2147483639;
				background:transparent;
				border: 0px;
				padding: 10px 10px 0px 0px;
				float: left;
				margin-right: -10px;
				backface-visibility:hidden;
				bottom: 35px;
				margin: 0 auto;
				right:0;
				left:0;
			}
			.lcustomchat
			{
				position: absolute; 
				display: none; 
				top: -5px; 
				right: -5px; 
				padding: 2px 7px; 
				cursor: pointer; 
				text-decoration: none; 
				color: rgb(0, 0, 0); 
				font-size: 20px; 
				font-family: Arial, sans-serif;
			}
			.icustomchat
			{
				display: block;
				overflow: hidden;
				cursor: pointer;
				text-align: center;
			}
@media screen and (max-width:768px)
{
	#my-wrapper
	{
		width:80%;
		margin:0 auto;
		right:0;
		left:0;
		
	}
}
