# ── Copy this file to .env and fill in your SMTP credentials ──
# Then run: node server.js

# Gmail SMTP (recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-character-app-password

# Where to send form submissions
TO_EMAIL=abbott@orchardmedicalmgt.com
FROM_EMAIL="OMM Website" <noreply@orchardmedicalmgt.com>

# Server port
PORT=3001

# ── How to get a Gmail App Password ──
# 1. Go to myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to App Passwords → create one for "Mail"
# 4. Paste the 16-character password as SMTP_PASS above
